---
const currentYear = new Date().getFullYear();
---
<footer class="footer">
    <div class="container footer-content">
        <div class="footer-bottom">
            <p>&copy; {currentYear} T&H Avanza&reg;. Todos los derechos reservados.</p>
            <div class="footer-legal">
                <a href="#">Aviso Legal</a>
                <a href="#">Política de Privacidad</a>
            </div>
        </div>
    </div>
</footer>

<style>
    .footer {
        background: #000000;
        color: #ffffff;
        padding: 4rem 2rem 2rem;
        margin-top: auto;
    }

    .footer-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 3rem;
    }

    .footer-brand {
        text-align: center;
    }

    .footer-logo {
        height: 80px;
        width: auto;
        border-radius: 12px;
        margin-bottom: 1rem;
        filter: grayscale(0.2) contrast(1.1);
    }

    .brand-tagline {
        font-size: 1.1rem;
        opacity: 0.7;
        max-width: 400px;
        font-weight: 500;
    }

    .footer-bottom {
        width: 100%;
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.9rem;
        opacity: 0.6;
    }

    .footer-legal {
        display: flex;
        gap: 2rem;
    }

    .footer-legal a:hover {
        color: var(--primary);
    }

    @media (max-width: 768px) {
        .footer-bottom {
            flex-direction: column;
            gap: 1.5rem;
            text-align: center;
        }
    }
</style>
