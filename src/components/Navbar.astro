---
<nav class="navbar">
    <div class="container nav-container">
        <a href="/" class="nav-logo">
            <img src="/logo.jpg" alt="Logo" />
        </a>
        <div class="nav-links">
            <a href="#nosotros" class="nav-link">Quiénes Somos</a>
            <a href="#whatsapp" class="nav-link nav-btn">Únete a WhatsApp</a>
        </div>
    </div>
</nav>

<style>
    .navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        height: 80px;
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(15px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        display: flex;
        align-items: center;
    }

    .nav-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 2rem;
    }

    .nav-logo img {
        height: 50px;
        width: auto;
        border-radius: 8px;
    }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 2rem;
    }

    .nav-link {
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--secondary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: var(--transition-smooth);
    }

    .nav-link:hover {
        color: var(--primary);
    }

    .nav-btn {
        background: var(--secondary);
        color: var(--primary);
        padding: 0.8rem 1.5rem;
        border-radius: 10px;
        font-size: 0.85rem;
    }

    .nav-btn:hover {
        color: #ffffff;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    @media (max-width: 768px) {
        .nav-links {
            gap: 1rem;
        }
        .nav-link {
            font-size: 0.8rem;
        }
        .nav-btn {
            padding: 0.6rem 1rem;
        }
    }
</style>
