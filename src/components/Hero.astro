---
---
<section class="hero">
    <div class="overlay"></div>
    <div class="container hero-content">
        <div class="logo-wrapper animate-up">
             <img src="/logo.jpeg" alt="T&H Avanza Logo" class="party-logo" />
        </div>
        <div class="cta-group animate-up delay-1">
            <a href="/contrato_electoral.pdf" download="Contrato_Electoral_tyhavanza.pdf" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Descargar Contrato Electoral
            </a>
        </div>
    </div>
</section>

<style>
    .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        background: #f8b508;
        color: #000000;
        padding: var(--section-padding);
        overflow: hidden;
    }

    .hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: radial-gradient(circle at 70% 30%, rgba(0, 0, 0, 0.05), transparent);
        pointer-events: none;
    }

    .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
        max-width: 900px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 3rem;
    }

    .logo-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
    }

    .party-logo {
        height: auto;
        width: 100%;
        max-width: 600px;
        mix-blend-mode: multiply;
        transition: var(--transition-smooth);
        mask-image: radial-gradient(circle, black 60%, transparent 100%);
        -webkit-mask-image: radial-gradient(circle, black 60%, transparent 100%);
    }

    .party-logo:hover {
        transform: scale(1.02);
    }

    .cta-group {
        display: flex;
        gap: 1rem;
        justify-content: center;
    }

    .animate-up {
        opacity: 0;
        transform: translateY(30px);
        animation: fadeInUp 0.8s forwards ease-out;
    }

    .delay-1 { animation-delay: 0.2s; }

    @keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 768px) {
        .party-logo {
            max-width: 90%;
        }
    }
</style>
