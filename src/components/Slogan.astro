<section class="slogan-section">
    <div class="container text-center">
        <h2 class="slogan-title animate-up">Gestión por objetivos, no por intereses políticos.</h2>
        <p class="slogan-subtitle animate-up delay-1">La buena gestión no tiene ideología, tiene soluciones.</p>
    </div>
</section>

<style>
    .slogan-section {
        padding: 6rem 2rem;
        background: #1a1a1a;
        color: #ffffff;
        position: relative;
    }

    .slogan-title {
        font-size: 3.5rem;
        line-height: 1.2;
        margin-bottom: 1.5rem;
        color: var(--primary);
        max-width: 1000px;
        margin-left: auto;
        margin-right: auto;
    }

    .slogan-subtitle {
        font-size: 1.5rem;
        opacity: 0.9;
        font-weight: 500;
        max-width: 800px;
        margin: 0 auto;
    }

    .animate-up {
        opacity: 0;
        transform: translateY(30px);
        animation: fadeInUp 0.8s forwards ease-out;
    }

    .delay-1 { animation-delay: 0.2s; }

    @keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 768px) {
        .slogan-section {
            padding: 4rem 1.5rem;
        }
        .slogan-title { 
            font-size: 2.5rem; 
        }
        .slogan-subtitle { 
            font-size: 1.2rem; 
        }
    }
</style>
