<style>
    .whatsapp-section {
        padding: var(--section-padding);
        background: #000000;
        color: #ffffff;
    }

    .whatsapp-card {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(248, 181, 8, 0.2);
        backdrop-filter: blur(10px);
        border-radius: 32px;
        padding: 4rem;
        text-align: center;
        max-width: 900px;
        margin: 0 auto;
    }

    .icon-blob {
        width: 100px;
        height: 100px;
        background: var(--primary);
        color: #000000;
        border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 2rem;
        animation: blob 8s infinite alternate;
    }

    @keyframes blob {
        0% { border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%; }
        100% { border-radius: 70% 30% 30% 70% / 70% 70% 30% 30%; }
    }

    h2 {
        font-size: 2.5rem;
        margin-bottom: 1rem;
        color: var(--primary);
    }

    p {
        font-size: 1.2rem;
        max-width: 600px;
        margin: 0 auto 3rem;
        opacity: 0.8;
    }

    .btn-whatsapp {
        background: #25D366;
        color: white;
        padding: 1.5rem 3rem;
        font-size: 1.25rem;
        border-radius: 50px;
    }

    .btn-whatsapp:hover {
        background: #128C7E;
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(37, 211, 102, 0.3);
    }
</style>
