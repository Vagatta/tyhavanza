---
const teamHerrera = [
    { name: "Gemma Rodríguez", role: "Representante en Herrera de Duero", image: "/gema_rodriguez.jpeg" },
    { name: "Manin", role: "Pasante", image: "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&q=80&w=400" }
];

const teamTudela = [
    { name: "Jorge Maeso", role: "Representante en Tudela de Duero", image: "/jorge_maeso.png" },
    { name: "Raúl", role: "Pasante", image: "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?auto=format&fit=crop&q=80&w=400" }
];
---
<section class="team" id="nosotros">
    <div class="container text-center">
        <h2 class="section-title">Quiénes Somos</h2>
        
        <div class="team-location">
            <h3 class="location-title">Equipo Herrera de Duero</h3>
            <div class="team-grid">
                {teamHerrera.map(member => (
                    <div class="team-card">
                        <div class="image-container">
                            <img src={member.image} alt={member.name} />
                        </div>
                        <div class="member-info">
                            <h4>{member.name}</h4>
                            <p>{member.role}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <div class="team-location">
            <h3 class="location-title">Equipo Tudela de Duero</h3>
            <div class="team-grid">
                {teamTudela.map(member => (
                    <div class="team-card">
                        <div class="image-container">
                            <img src={member.image} alt={member.name} />
                        </div>
                        <div class="member-info">
                            <h4>{member.name}</h4>
                            <p>{member.role}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>

    </div>
</section>

<style>
    .team {
        padding: var(--section-padding);
        background: #ffffff;
    }

    .section-title {
        font-size: 3rem;
        text-align: center;
        margin-bottom: 4rem;
        position: relative;
        display: inline-block;
        left: 50%;
        transform: translateX(-50%);
        color: var(--secondary);
    }

    .section-title::after {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 0;
        width: 60px;
        height: 6px;
        background: var(--primary);
    }

    .team-location {
        margin-bottom: 5rem;
    }

    .team-location:last-child {
        margin-bottom: 0;
    }

    .location-title {
        font-size: 2rem;
        color: var(--secondary);
        margin-bottom: 3rem;
        text-align: left;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--border);
    }

    .team-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2.5rem;
    }

    .team-card {
        background: #ffffff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        transition: var(--transition-smooth);
        border: 1px solid var(--border);
    }

    .team-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        border-color: var(--primary);
    }

    .image-container {
        height: 350px;
        overflow: hidden;
    }

    .image-container img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center;
        background-color: #fafafa;
        transition: var(--transition-smooth);
    }

    .member-info {
        padding: 2rem;
        text-align: center;
    }

    .member-info h4 {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
        color: var(--secondary);
        font-family: var(--font-heading);
    }

    .member-info p {
        color: #666;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.1em;
    }

    .text-center { text-align: center; }

    @media (max-width: 768px) {
        .location-title {
            text-align: center;
            font-size: 1.5rem;
        }
    }
</style>
